# rcab — dev environment variables
# Copy to .env.dev (gitignored) and adjust as needed.
# Every variable read by docker-compose.dev.yml is documented here.

# ---- Postgres ---------------------------------------------------------------
POSTGRES_USER=rcab
POSTGRES_PASSWORD=rcab
POSTGRES_DB=rcab

# ---- Redis ------------------------------------------------------------------
# REDIS_URL is constructed inside compose as redis://redis:6379 — override only
# if you point dev api at a remote redis.

# ---- OSRM -------------------------------------------------------------------
# URL of the OSM PBF file the osrm container downloads on first boot.
# Default: Geofabrik north-eastern-zone India extract (~103 MB — the smallest
# of the six India zonal extracts). First boot takes ~5–10 min to preprocess;
# subsequent boots reuse the cached osrm-data volume.
# Switch to a different zone for your pilot city (or the full india-latest).
OSM_PBF_URL=https://download.geofabrik.de/asia/india/north-eastern-zone-latest.osm.pbf

# ---- API --------------------------------------------------------------------
# PORT is fixed at 3000 inside the container; the host publishes it as 3000.
# DATABASE_URL is constructed from the POSTGRES_* vars above.

# ---- Web --------------------------------------------------------------------
# Host publishes web on 3002 (api uses 3000).
NEXT_PUBLIC_API_URL=http://localhost:3000
