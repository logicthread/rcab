{
  "name": "rcab",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "dev": "turbo dev",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "docker compose --env-file .env.dev -f infra/docker/docker-compose.dev.yml down",
    "dev:logs": "docker compose --env-file .env.dev -f infra/docker/docker-compose.dev.yml logs -f",
    "dev:smoke": "bash scripts/dev-smoke.sh",
    "system:probe": "echo 'system:probe not yet implemented — see RCAB-E1.S9'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
