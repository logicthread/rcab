# Obsidian — per-machine workspace state, not vault content
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/.trash/

# Empty/accidental Obsidian canvases
Untitled*.canvas

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo

# Working scratchpad files (per LLM-INSTRUCTIONS §8 — ephemeral)
WORKING.md

# System probe report (machine-local, never committed)
system-probe-report.json

# Code graph staleness flag (machine-local; graph.json/graph.md ARE committed)
codegraph/.stale
codegraph/memory-ingest.json

# --- Future code (monorepo) — ignored ahead of time so accidental builds don't pollute commits

# Node / pnpm / turbo
node_modules/
.pnpm-store/
.turbo/
dist/
build/
.next/
out/
coverage/
*.tsbuildinfo

# Env files (no secrets in git, ever)
.env
.env.*
!.env.example
!.env.*.example

# Flutter / Dart
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/build/
**/ios/Pods/
**/android/.gradle/
**/android/local.properties

# Firebase secrets — never commit the real file; use *.example as the template
apps/driver-app/android/app/google-services.json

# Generated API client / migrations artifacts
apps/*/src/generated/
apps/api/migrations/*.snapshot
