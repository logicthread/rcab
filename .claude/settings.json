{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(pnpm build)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm dev)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm system:probe)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm --version)",
      "Bash(pnpm approve-builds *)",
      "Bash(docker compose *)",
      "Bash(docker --version)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git checkout -- *)",
      "Bash(git commit -m *)",
      "Bash(corepack --version)",
      "Bash(corepack enable *)",
      "Bash(corepack install *)",
      "Bash(corepack prepare *)",
      "Bash(chmod +x *)",
      "Bash(curl -s* https://download.geofabrik.de/*)",
      "Bash(curl -sI* https://download.geofabrik.de/*)",
      "Bash(curl -sI http://localhost:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(npm view *)",
      "Bash(npm list *)",
      "Bash(sw_vers*)",
      "Bash(sysctl -n *)",
      "Bash(docker pull *)",
      "Bash(docker rm -f *)",
      "Bash(docker network *)",
      "Bash(docker volume *)",
      "Bash(pnpm -F *)",
      "Bash(pnpm test:int)",
      "Bash(pnpm test:int *)",
      "Bash(RCAB_SKIP_INT=1 pnpm test:int)",
      "Bash(pnpm prod:*)",
      "Write(.claude/hooks/**)",
      "Write(.claude/skills/**)",
      "Edit(.claude/hooks/**)",
      "Edit(.claude/skills/**)",
      "Write(infra/docker/**)",
      "Edit(infra/docker/**)",
      "Write(scripts/*)",
      "Edit(scripts/*)",
      "Write(.github/workflows/**)",
      "Edit(.github/workflows/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-story-trailer.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-vault-links.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-vault-links.sh"
          }
        ]
      }
    ]
  }
}
